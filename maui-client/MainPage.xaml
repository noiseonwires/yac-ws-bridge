<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BridgeToFreedom.MainPage"
    Title="Bridge to Freedom">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <!-- Settings Card -->
        <Border Grid.Row="0" StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                Background="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Padding="16">
            <VerticalStackLayout Spacing="12">

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="Connection Settings" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="Import" FontSize="12" Padding="12,4"
                            HeightRequest="32"
                            Clicked="OnImportClicked"
                            BackgroundColor="{AppThemeBinding Light=#E8E0F7, Dark=#3A3060}"
                            TextColor="{AppThemeBinding Light=#512BD4, Dark=#C8B8F0}" />
                    <Button Grid.Column="2" Text="Export" FontSize="12" Padding="12,4"
                            HeightRequest="32"
                            Clicked="OnExportClicked"
                            BackgroundColor="{AppThemeBinding Light=#E8E0F7, Dark=#3A3060}"
                            TextColor="{AppThemeBinding Light=#512BD4, Dark=#C8B8F0}" />
                </Grid>

                <!-- Bridge URL -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Bridge URL" FontSize="12"
                           TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                    <Entry x:Name="BridgeUrlEntry"
                           Text="wss://"
                           Placeholder="wss://gateway.example.com/_helper"
                           Keyboard="Url"
                           IsEnabled="{Binding IsNotRunning}" />
                </VerticalStackLayout>

                <!-- Auth Token -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Auth Token" FontSize="12"
                           TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                    <Entry x:Name="AuthTokenEntry"
                           Placeholder="shared secret"
                           IsPassword="True"
                           IsEnabled="{Binding IsNotRunning}" />
                </VerticalStackLayout>

                <!-- Listen Address + Port -->
                <Grid ColumnDefinitions="2*,*" ColumnSpacing="8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Listen Address" FontSize="12"
                               TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                        <Entry x:Name="ListenAddressEntry"
                               Text="127.0.0.1"
                               IsEnabled="{Binding IsNotRunning}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Port" FontSize="12"
                               TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
                        <Entry x:Name="ListenPortEntry"
                               Text="1080"
                               Keyboard="Numeric"
                               IsEnabled="{Binding IsNotRunning}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Relay toggle -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Relay mode (send via Cloud Function)"
                           VerticalOptions="Center" FontSize="13" />
                    <Switch x:Name="RelaySwitch" Grid.Column="1"
                            IsEnabled="{Binding IsNotRunning}" />
                </Grid>

                <!-- Connect / Disconnect Button -->
                <Button x:Name="ConnectButton"
                        Text="CONNECT"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="50"
                        Clicked="OnConnectClicked"
                        BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7B5FD4}"
                        TextColor="White" />
            </VerticalStackLayout>
        </Border>

        <!-- Log area -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 12" StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                Background="{AppThemeBinding Light=#F8F8F8, Dark=#111111}"
                Padding="0">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" StrokeThickness="0" Padding="12,8"
                        Background="{AppThemeBinding Light=#EEEEEE, Dark=#222222}">
                    <Label Text="Log" FontSize="14" FontAttributes="Bold" />
                </Border>
                <ScrollView x:Name="LogScrollView" Grid.Row="1">
                    <Label x:Name="LogLabel"
                           FontFamily="Consolas, monospace"
                           FontSize="11"
                           Padding="12,8"
                           LineHeight="1.3"
                           VerticalOptions="Start"
                           TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
