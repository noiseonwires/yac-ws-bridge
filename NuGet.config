<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Public NuGet -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      Microsoft's public dotnet feeds. Required because some .NET runtime packs
      (e.g. Microsoft.NETCore.App.Runtime.Mono.win-x64 for the latest 10.x
      patch) ship here before — or instead of — nuget.org. Without this feed,
      `dotnet publish` for the MAUI Windows / Android target may fail with
      NU1102 ("Unable to find package ... with version (= 10.0.x)").
    -->
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" />
    <add key="dotnet10" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet10/nuget/v3/index.json" />
  </packageSources>
</configuration>
